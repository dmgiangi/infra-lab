#cloud-config
preserve_hostname: false
hostname: ${hostname}
fqdn: ${hostname}

ssh_pwauth: false
disable_root: true

users:
  - default
  - name: ${ssh_username}
    groups:
      - adm
      - sudo
    shell: /bin/bash
    sudo:
      - ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true
    ssh_authorized_keys:
%{ for key in ssh_authorized_keys ~}
      - ${key}
%{ endfor ~}

package_update: true
packages:
  - qemu-guest-agent
runcmd:
  - systemctl enable --now qemu-guest-agent
